    "cognitive-disability",
    "education",
    "educational-tool",
    "esat",
    "ime",
    "savs",
    "medico-social",
    "autonomie",
    "vue3",
    "vite",
    "pwa",
    "open-source"
  ],
  "homepage": "https://cedric-ruiu.github.io/atm-trainer/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cedric-ruiu/atm-trainer.git"
  },
  "bugs": {
    "url": "https://github.com/Cedric-ruiu/atm-trainer/issues"
  },
